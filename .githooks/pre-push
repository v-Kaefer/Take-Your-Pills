#!/usr/bin/env bash
set -euo pipefail

ZERO_SHA="0000000000000000000000000000000000000000"
LOG_PREFIX="[pre-push]"
VERBOSE="${PRE_PUSH_VERBOSE:-0}"

if ((BASH_VERSINFO[0] < 4)); then
  echo "$LOG_PREFIX Bash 4+ is required for this hook; current version is ${BASH_VERSION:-unknown}." >&2
  echo "$LOG_PREFIX On macOS, install a newer Bash and run the hook with that interpreter." >&2
  exit 1
fi

remote_name="${1:-}"
remote_url="${2:-}"

log_step() {
  echo "$LOG_PREFIX $*"
}

log_verbose() {
  if [[ "$VERBOSE" == "1" ]]; then
    echo "$LOG_PREFIX [verbose] $*"
  fi
}

fail_with() {
  echo "$LOG_PREFIX $*" >&2
  exit 1
}

indent_lines() {
  sed 's/^/  /'
}

collect_ref_updates() {
  local -n updates_ref="$1"
  if [[ -t 0 ]]; then
    log_step "mode: interactive terminal; running local upstream comparison."
    local head_ref upstream_short remote_ref local_sha remote_sha
    head_ref="$(git symbolic-ref -q HEAD || true)"
    [[ -n "$head_ref" ]] || fail_with "detached HEAD is not supported for manual pre-push runs."
    upstream_short="$(git rev-parse --abbrev-ref --symbolic-full-name @{upstream} 2>/dev/null || true)"
    [[ -n "$upstream_short" ]] || fail_with "no upstream configured for ${head_ref#refs/heads/}. Set it with: git push -u origin ${head_ref#refs/heads/}"
    remote_ref="$(git for-each-ref --format='%(upstream:remoteref)' "$head_ref")"
    [[ -n "$remote_ref" ]] || fail_with "unable to determine upstream ref for ${head_ref#refs/heads/}."
    local_sha="$(git rev-parse HEAD)"
    remote_sha="$(git rev-parse "$upstream_short")"
    log_verbose "manual refs: local_ref=$head_ref local_sha=$local_sha remote_ref=$remote_ref remote_sha=$remote_sha"
    updates_ref=("$head_ref $local_sha $remote_ref $remote_sha")
    return 0
  fi

  log_step "mode: git hook stdin; reading refs queued by git push."
  mapfile -t updates_ref
}

normalize_status() {
  local raw="${1,,}"
  raw="${raw%%[^a-z]*}"
  case "$raw" in
    a|added) echo "added" ;;
    m|modified|changed|"") echo "modified" ;;
    d|deleted|removed) echo "removed" ;;
    r|renamed) echo "renamed" ;;
    c|copied) echo "copied" ;;
    *) echo "$raw" ;;
  esac
}

classify_sector() {
  local path="${1//\\//}"
  local normalized="${path,,}"
  case "$normalized" in
    scenes/player/*|scripts/player/*|scripts/character/*) echo "gameplay|Player systems|Player input, movement, or player scene wiring changed." ;;
    scenes/game/game.gd|scenes/game/game.tscn|scripts/run_signals.gd) echo "gameplay|Core gameplay loop|The main game flow, state transitions, or scene bootstrapping changed." ;;
    scenes/game/chunks/*|scenes/game/chunk_manager*|scripts/chunks/*|scripts/world/*) echo "gameplay|Chunk generation|Chunk streaming, world assembly, or terrain-loading logic changed." ;;
    scenes/game/obstacles/*|scripts/obstacles/*) echo "gameplay|Obstacle systems|Obstacle spawning, collision, or obstacle content changed." ;;
    scenes/game/hud*|scenes/game/ui*|ui/*) echo "gameplay|HUD / UI|HUD, menus, or in-game status presentation changed." ;;
    scenes/game/*|scenes/*) echo "gameplay|Game scenes|General scene content or Godot resources in the game layer changed." ;;
    *.gd|*.tscn|*.tres) echo "gameplay|Godot content|Godot scene or resource files changed outside the main gameplay folders." ;;
    .github/workflows/*|.github/*|scripts/validation/*|scripts/github/*|scripts/hooks/*) echo "support|Automation / CI|Validation, release, or repository automation changed." ;;
    config/*|project.godot) echo "support|Configuration|Repository or project configuration changed." ;;
    docs/*) echo "support|Documentation|Documentation or runbook text changed." ;;
    tests/*) echo "support|Tests|Test coverage, fixtures, or test helpers changed." ;;
    scripts/*) echo "support|General scripts|Repository helper scripts changed." ;;
    *) echo "support|Other|Files changed." ;;
  esac
}

parse_diff_paths() {
  local line="$1"
  local status first second third path
  IFS=$'\t' read -r first second third <<< "$line"
  status="$(normalize_status "$first")"
  if [[ -n "${third:-}" && ( "$status" == "renamed" || "$status" == "copied" ) ]]; then
    path="$third"
  elif [[ -n "${second:-}" ]]; then
    path="$second"
  else
    path="$first"
  fi
  printf '%s\t%s\n' "$status" "$path"
}

render_ref_summary() {
  local title="$1"
  shift
  local lines=("$@")
  declare -A status_counts=()
  declare -A folder_counts=()
  declare -A sector_counts=()
  declare -A sector_examples=()
  local item_count=0
  local sector_count=0

  for line in "${lines[@]}"; do
    [[ -z "$line" ]] && continue
    local parsed status path folder top sector_info category sector impact current_examples
    parsed="$(parse_diff_paths "$line")"
    status="${parsed%%$'\t'*}"
    path="${parsed#*$'\t'}"
    [[ -z "$path" ]] && continue
    item_count=$((item_count + 1))

    status_counts["$status"]=$(( ${status_counts["$status"]:-0} + 1 ))

    if [[ "$path" == */* ]]; then
      top="${path%%/*}"
      folder="$top"
    else
      folder="(root)"
    fi
    folder_counts["$folder"]=$(( ${folder_counts["$folder"]:-0} + 1 ))

    sector_info="$(classify_sector "$path")"
    category="${sector_info%%|*}"
    sector_info="${sector_info#*|}"
    sector="${sector_info%%|*}"
    impact="${sector_info#*|}"
    if [[ -z "${sector_counts["$sector"]+set}" ]]; then
      sector_count=$((sector_count + 1))
      sector_examples["$sector"]="$category|$impact|$path"
      sector_counts["$sector"]=1
    else
      sector_counts["$sector"]=$(( ${sector_counts["$sector"]} + 1 ))
      current_examples="${sector_examples["$sector"]}"
      if [[ "$current_examples" != *"|$path"* ]]; then
        sector_examples["$sector"]="${current_examples}|$path"
      fi
    fi
  done

  echo "## Change summary"
  echo
  echo "- PR: $title"
  echo "- $item_count files changed across $sector_count sectors."
  if ((${#status_counts[@]})); then
    local keys key counts_line=""
    mapfile -t keys < <(printf '%s\n' "${!status_counts[@]}" | sort)
    for key in "${keys[@]}"; do
      counts_line+="${counts_line:+, }${key}: ${status_counts[$key]}"
    done
    echo "- Status counts: $counts_line."
  fi
  if ((${#folder_counts[@]})); then
    local folders folder_line="" folder_name label
    mapfile -t folders < <(for folder_name in "${!folder_counts[@]}"; do printf '%s\t%s\n' "${folder_counts[$folder_name]}" "$folder_name"; done | sort -rn -k1,1 -k2,2)
    for entry in "${folders[@]}"; do
      local count
      count="${entry%%$'\t'*}"
      folder_name="${entry#*$'\t'}"
      label="$folder_name"
      [[ "$folder_name" == "(root)" ]] && label="repository root"
      folder_line+="${folder_line:+, }${label} (${count})"
    done
    echo "- Top-level folders: $folder_line."
  fi
  echo

  render_sector_section() {
    local header="$1"
    local kind="$2"
    local printed=0
    local names=()
    local sector_name
    for sector_name in "${!sector_counts[@]}"; do
      if [[ "${sector_examples[$sector_name]}" == "$kind|"* ]]; then
        names+=("$sector_name")
      fi
    done
    if ((${#names[@]} == 0)); then
      return 0
    fi
    mapfile -t names < <(for sector_name in "${names[@]}"; do printf '%s\t%s\n' "${sector_counts[$sector_name]}" "$sector_name"; done | sort -rn -k1,1 -k2,2)
    echo "$header"
    for entry in "${names[@]}"; do
      local count
      count="${entry%%$'\t'*}"
      sector_name="${entry#*$'\t'}"
      local file_label="files"
      (( count == 1 )) && file_label="file"
      local payload impact samples joined sample_a sample_b rest
      payload="${sector_examples[$sector_name]}"
      payload="${payload#*|}"
      impact="${payload%%|*}"
      samples="${payload#*|}"
      IFS='|' read -r sample_a sample_b rest <<< "$samples"
      echo "- $sector_name ($count $file_label)"
      echo "  - $impact"
      if [[ -n "${sample_b:-}" ]]; then
        local more=$((count - 2))
        if ((more > 0)); then
          joined="\`$sample_a\`, \`$sample_b\`, and $more more"
        else
          joined="\`$sample_a\`, \`$sample_b\`"
        fi
        echo "  - Examples: $joined"
      else
        echo "  - Example: \`$sample_a\`"
      fi
      printed=1
    done
    ((printed == 1)) && echo
  }

  render_sector_section "### Gameplay impact" "gameplay"
  render_sector_section "### Support changes" "support"
}

lint_python_file() {
  local path="$1"
  local message
  if ! message="$(python3 - "$path" 2>&1 <<'PY'
import ast
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
try:
    source = path.read_text(encoding="utf-8")
except Exception as exc:  # noqa: BLE001
    print(exc)
    raise SystemExit(1)

try:
    ast.parse(source, filename=str(path))
except SyntaxError as exc:
    print(exc)
    raise SystemExit(1)
PY
)"; then
    printf '%s: %s\n' "$path" "$message"
    return 1
  fi
}

lint_shell_file() {
  local path="$1"
  local message
  if ! message="$(bash -n "$path" 2>&1)"; then
    message="${message:-shell syntax check failed}"
    printf '%s: %s\n' "$path" "$message"
    return 1
  fi
}

lint_json_file() {
  local path="$1"
  local message
  if ! message="$(python3 - "$path" 2>&1 <<'PY'
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
with path.open("r", encoding="utf-8") as handle:
    json.load(handle)
PY
)"; then
    printf '%s: %s\n' "$path" "$message"
    return 1
  fi
}

lint_yaml_file() {
  local path="$1"
  local message status
  message="$(python3 - "$path" 2>&1 <<'PY'
import pathlib
import sys

path = pathlib.Path(sys.argv[1])

try:
    import yaml  # type: ignore
except Exception:
    raise SystemExit(3)

with path.open("r", encoding="utf-8") as handle:
    yaml.safe_load(handle)
PY
)"
  status=$?
  if ((status != 0)); then
    if ((status == 3)); then
      printf 'WARN:%s: skipped YAML check because PyYAML is not available\n' "$path"
      return 0
    fi
    printf '%s: %s\n' "$path" "$message"
    return 1
  fi
}

lint_toml_file() {
  local path="$1"
  local message
  if ! message="$(python3 - "$path" 2>&1 <<'PY'
import pathlib
import sys

path = pathlib.Path(sys.argv[1])

try:
    import tomllib
except Exception:
    print("TOML validation is unavailable in this Python version")
    raise SystemExit(1)

with path.open("rb") as handle:
    tomllib.load(handle)
PY
)"; then
    printf '%s: %s\n' "$path" "$message"
    return 1
  fi
}

echo "pre-push audit for ${remote_name:-remote}"
echo "remote: ${remote_url:-unknown}"

updates=()
collect_ref_updates updates
log_step "refs queued for analysis: ${#updates[@]}"
if ((${#updates[@]} == 0)); then
  echo "No refs were queued for push."
  exit 0
fi

empty_tree="$(git hash-object -t tree /dev/null)"
all_paths=()
pushed_shas=()

for update_line in "${updates[@]}"; do
  [[ -z "${update_line//[[:space:]]/}" ]] && continue
  read -r local_ref local_sha remote_ref remote_sha <<< "$update_line"
  if [[ -z "${local_ref:-}" || -z "${local_sha:-}" || -z "${remote_ref:-}" || -z "${remote_sha:-}" ]]; then
    continue
  fi

  log_step "analyzing ref ${local_ref} -> ${remote_ref}"
  echo "ref: $local_ref -> $remote_ref"
  if [[ "$local_sha" == "$ZERO_SHA" ]]; then
    echo "  deletion detected; no file summary available."
    continue
  fi
  pushed_shas+=("$local_sha")

  base_sha="$remote_sha"
  [[ "$remote_sha" == "$ZERO_SHA" ]] && base_sha="$empty_tree"
  log_verbose "diff base=$base_sha head=$local_sha"
  mapfile -t diff_lines < <(git diff --name-status "$base_sha" "$local_sha")
  if ((${#diff_lines[@]} == 0)); then
    echo "  no file changes detected."
    continue
  fi

  render_ref_summary "$local_ref -> $remote_ref" "${diff_lines[@]}" | indent_lines
  echo

  for line in "${diff_lines[@]}"; do
    parsed="$(parse_diff_paths "$line")"
    path="${parsed#*$'\t'}"
    [[ -n "$path" ]] || continue
    all_paths+=("$path")
  done
done

lint_errors=()
lint_warnings=()
checked=()
lintable_count=0

if ((${#all_paths[@]})); then
  while IFS= read -r path; do
    [[ -n "$path" ]] || continue
    [[ -e "$path" ]] || continue
    checked+=("$path")

    message=""
    case "$path" in
      *.py)
        lintable_count=$((lintable_count + 1))
        log_verbose "lint python: $path"
        if ! message="$(lint_python_file "$path")"; then
          lint_errors+=("$message")
        fi
        ;;
      *.sh)
        lintable_count=$((lintable_count + 1))
        log_verbose "lint shell: $path"
        if ! message="$(lint_shell_file "$path")"; then
          lint_errors+=("$message")
        fi
        ;;
      *.yml|*.yaml)
        lintable_count=$((lintable_count + 1))
        log_verbose "lint yaml: $path"
        if message="$(lint_yaml_file "$path")"; then
          :
        else
          lint_errors+=("$message")
        fi
        if [[ "$message" == WARN:* ]]; then
          lint_warnings+=("${message#WARN:}")
        fi
        ;;
      *.json)
        lintable_count=$((lintable_count + 1))
        log_verbose "lint json: $path"
        if ! message="$(lint_json_file "$path")"; then
          lint_errors+=("$message")
        fi
        ;;
      *.toml)
        lintable_count=$((lintable_count + 1))
        log_verbose "lint toml: $path"
        if ! message="$(lint_toml_file "$path")"; then
          lint_errors+=("$message")
        fi
        ;;
    esac
  done < <(printf '%s\n' "${all_paths[@]}" | sort -u)
fi

log_step "lint stage: ${lintable_count} lintable file(s), ${#checked[@]} changed file(s) considered."
echo "lint checks"
if ((${#lint_errors[@]})); then
  log_step "result: failed (${#lint_errors[@]} lint error(s))."
  {
    echo "Lint checks failed."
    for err in "${lint_errors[@]}"; do
      echo "- $err"
    done
    if ((${#lint_warnings[@]})); then
      echo "Warnings:"
      for warning in "${lint_warnings[@]}"; do
        echo "- $warning"
      done
    fi
  } | indent_lines
  exit 1
fi

log_step "result: passed."
{
  if ((${#checked[@]} == 0)); then
    echo "Lint checks: no lintable files detected."
  else
    echo "Lint checks passed for ${#checked[@]} changed file(s)."
  fi
  if ((${#lint_warnings[@]})); then
    echo "Warnings:"
    for warning in "${lint_warnings[@]}"; do
      echo "- $warning"
    done
  fi
} | indent_lines

gameplay_changed=()
tests_changed=()
for _path in "${all_paths[@]}"; do
  _sector_info="$(classify_sector "$_path")"
  _sector_category="${_sector_info%%|*}"
  if [[ "$_sector_category" == "gameplay" ]]; then
    gameplay_changed+=("$_path")
  fi
  case "$_path" in
    tests/*) tests_changed+=("$_path") ;;
  esac
done

if ((${#gameplay_changed[@]} > 0)); then
  echo "segment coverage check"
  if ((${#tests_changed[@]} == 0)); then
    {
      echo "WARNING: gameplay files changed but no test files were included."
      echo "Changed gameplay files:"
      for _gp in "${gameplay_changed[@]}"; do
        echo "  - $_gp"
      done
      echo "Consider adding or updating tests in tests/godot/ to cover these changes."
    } | indent_lines
  else
    {
      echo "Gameplay changes detected with test files present."
      echo "Changed gameplay files (${#gameplay_changed[@]}): ${gameplay_changed[*]}"
      echo "Changed test files    (${#tests_changed[@]}): ${tests_changed[*]}"
    } | indent_lines
  fi
fi

if ((${#pushed_shas[@]} > 0)) && [[ -n "${remote_name:-}" ]]; then
  for _sha in "${pushed_shas[@]}"; do
    git push "$remote_name" "${_sha}:refs/coverage-approved/${_sha}" --no-verify 2>/dev/null || true
  done
fi
