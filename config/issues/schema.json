{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Issue Tree Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "epics"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "labels": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "assignees": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "milestone": { "type": ["string", "number"] },
        "body": { "type": "string" }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "owner": { "type": "string", "minLength": 1 },
        "number": { "type": "integer", "minimum": 1 },
        "fieldsFile": { "type": "string", "minLength": 1 },
        "statusOnCreate": { "type": "string", "minLength": 1 },
        "extraFieldValues": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 1 }
        }
      }
    },
    "linking": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "subIssueStrategy": {
          "type": "string",
          "enum": ["graphql_or_comment"]
        }
      }
    },
    "epics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/epic"
      }
    }
  },
  "$defs": {
    "issue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "type",
        "area",
        "priority"
      ],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": ["epic", "feature", "task", "bug", "chore"]
        },
        "area": {
          "type": "string",
          "enum": ["gameplay", "ui", "art", "audio", "infra", "docs", "automation"]
        },
        "priority": {
          "type": "string",
          "enum": ["p0", "p1", "p2", "p3"]
        },
        "body": { "type": "string" },
        "labels": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "assignees": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "milestone": { "type": ["string", "number"] },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/issue" }
        }
      }
    },
    "epic": {
      "allOf": [
        { "$ref": "#/$defs/issue" },
        {
          "properties": {
            "type": { "const": "epic" }
          }
        }
      ]
    }
  }
}
